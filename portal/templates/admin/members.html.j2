{% extends "base.html.j2" %}

{% from "paginate.html.j2" import render_pagination %}

{% block title %}Members{% endblock %}

{% block contents %}
<div class="container">
    <h1>Members</h1>
    <ul class="item-list">
        {% for member in page %}
        <li class="item-box">
            <dl>
            <dt>Display Name</dt>
            <dd>{{ member.display_name }}</dd>
            <dt>Email</dt>
            <dd>{{ member.email }}</dd>
            </dl>
        </li>
        {% endfor %}
    </ul>
    {{ render_pagination(page, 'admin.members') }}
</div>
{% endblock %}