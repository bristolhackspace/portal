{% extends "base.html.j2" %}

{% import 'wtforms.html.j2' as wtf %}

{% block title %}Login{% endblock %}

{% block contents %}
<div class="container">
    <div class="item-box">
        <p>Logging in to the Hackspace Forum and Wiki has changed.</p>
        <p>This is the new Hackspace Single-Sign-On system. </p>
        <p>Enter the email address you use to access our forum below, and we'll email you a login code / link.</p>
    </div>
    <h1>Login to your account</h1>
    <form method="POST" class="form">
        <fieldset>
            {{ form.hidden_tag() }}
            {{ wtf.input(form.email, form) }}
            <p><button type="submit" class="btn btn-primary">Request one-time login code</button></p>
        </fieldset>
    </form>
</div>
{% endblock %}
