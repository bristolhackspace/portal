{% extends "base.html.j2" %}

{% import 'wtforms.html.j2' as wtf %}

{% block title %}Login{% endblock %}

{% block contents %}
<div class="container">
    <h1>Login to your account</h1>
    <form method="POST" class="form">
        <fieldset>
            {{ form.hidden_tag() }}
            {{ wtf.input(form.otp, form, autocomplete="one-time-code", field_class="otp-field", inputmode="numeric", autofocus="") }}
            <button type="submit" class="btn btn-primary">Submit</button>
            {% if resend_email_url %}
            or <a href="{{resend_email_url}}">requset a new code</a>.
            {% endif %}
        </fieldset>
    </form>
</div>
{% endblock %}
